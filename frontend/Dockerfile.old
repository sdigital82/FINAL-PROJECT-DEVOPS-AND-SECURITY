FROM nginx:1.27.3-alpine

# Copy custom config BEFORE entrypoint runs
COPY nginx.conf /etc/nginx/nginx.conf

# Create dirs + permissions BEFORE user switch
RUN mkdir -p /var/cache/nginx/client_temp \
    /var/cache/nginx/proxy_temp \
    /var/cache/nginx/fastcgi_temp \
    /var/cache/nginx/uwsgi_temp \
    /var/cache/nginx/scgi_temp \
    /var/log/nginx \
    && chmod -R 755 /var/cache/nginx /var/log/nginx /var/run

# Copy html/css AFTER permissions
COPY html/ /usr/share/nginx/html/
COPY css/ /usr/share/nginx/html/css/

# Fix ownership
RUN chown -R nginx:nginx /usr/share/nginx/html /var/log/nginx /var/run

# Run as non-root
USER nginx

# Skip entrypoint scripts + run nginx directly
ENTRYPOINT []
CMD ["nginx", "-g", "daemon off;"]
